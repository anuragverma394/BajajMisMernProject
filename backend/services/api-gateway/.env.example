NODE_ENV=development
SERVICE_NAME=api-gateway
PORT=5000

# CORS Configuration - specify allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Security Headers
SECURITY_HEADERS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_MS=900000

# JWT Configuration
JWT_SECRET=YOUR_SECURE_JWT_SECRET_KEY_HERE
JWT_EXPIRES_IN=24h
APP_JWT_SECRET=YOUR_SECURE_JWT_SECRET_KEY_HERE

# Logging & Monitoring
LOG_LEVEL=info
REQUEST_LOGGING=true

# Service URLs
AUTH_SERVICE_URL=http://localhost:5001
USER_SERVICE_URL=http://localhost:5002
DASHBOARD_SERVICE_URL=http://localhost:5003
REPORT_SERVICE_URL=http://localhost:5004
LAB_SERVICE_URL=http://localhost:5005
SURVEY_SERVICE_URL=http://localhost:5006
TRACKING_SERVICE_URL=http://localhost:5007
DISTILLERY_SERVICE_URL=http://localhost:5008
WHATSAPP_SERVICE_URL=http://localhost:5009

# Service Configuration
SERVICE_TIMEOUT=30000
DEFAULT_SEASON=2526

# Database Configuration (if needed for gateway)
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=BajajMis
DB_USE_WINDOWS_AUTH=true