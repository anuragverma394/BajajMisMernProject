# ============================================
# DATABASE CONFIGURATION
# ============================================

# Skip database connection for development/testing
# Set to false when ready to connect to real database
SKIP_DB_CONNECT=true

# Disable Windows Authentication (msnodesqlv8 not available)
DB_USE_WINDOWS_AUTH=false

# SQL Server Connection (when SKIP_DB_CONNECT=false)
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=BajajMIS
DB_USER=sa
DB_PASSWORD=

# Connection pool settings
DB_POOL_MAX=10
DB_POOL_MIN=2

# Timeouts (milliseconds)
SQL_REQUEST_TIMEOUT_MS=300000
SQL_CONNECTION_TIMEOUT_MS=30000

# ============================================
# SERVICE CONFIGURATION
# ============================================

# Node environment
NODE_ENV=development

# API Gateway Port
API_GATEWAY_PORT=5000

# Service Ports
AUTH_SERVICE_PORT=5001
USER_SERVICE_PORT=5002
DASHBOARD_SERVICE_PORT=5003
REPORT_SERVICE_PORT=5004
TRACKING_SERVICE_PORT=5005
SURVEY_SERVICE_PORT=5006
LAB_SERVICE_PORT=5007
DISTILLERY_SERVICE_PORT=5008
WHATSAPP_SERVICE_PORT=5009

# ============================================
# CACHE & REDIS
# ============================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ============================================
# LOGGING
# ============================================

LOG_LEVEL=info

# ============================================
# JWT & SECURITY
# ============================================

JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY=24h

# ============================================
# CORS & SECURITY
# ============================================

CORS_ORIGIN=http://localhost:3000,http://localhost:3001
